# copy file nay thanh .env va sua theo he thong
# .env khong commit len git (da co trong .gitignore)

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eaut_db
POSTGRES_USER=eaut_admin
POSTGRES_PASSWORD=eaut_password

# pgAdmin (tuy chon, chi de xem database qua browser)
PGADMIN_EMAIL=admin@eaut.edu.vn
PGADMIN_PASSWORD=admin123
